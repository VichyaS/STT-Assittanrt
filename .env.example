# ==========================================
# AI VICHYA - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# === Required: OpenRouter API Key ===
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === Optional: CORS Origin (production) ===
# Set to your domain in production, e.g. https://vichya.example.com
# Leave empty or "*" for development
CORS_ORIGIN=*

# === Optional: Production Mode ===
# Set to "1" to enable HSTS and other production security features
ENABLE_HSTS=0

# === Optional: Flask Debug Mode ===
# Set to "1" to enable debug mode (NOT for production)
FLASK_DEBUG=0